# Python
__pycache__/
*.py[cod]
*.egg-info/
.venv/
venv/
.pytest_cache/
.mypy_cache/

# Node / Vite
node_modules/
dist/
.vite/

# Env / secrets (there should be NO real secrets or PII in this repo — all data is synthetic)
.env
.env.*
*.key
*.pem

# OS / editor
.DS_Store
Thumbs.db
.idea/
.vscode/

# Local model artifacts that may grow large (Phase 3 logs choice in DECISIONS.md)
# models/*.joblib

# Model & dataset store (plan §9): large binaries (LayoutLMv3, DocTamper, PaddleOCR, LMDB data).
# NEVER committed. Only the registry (REGISTRY.md + registry.json) is tracked so the team knows
# what should be there and how to get it; code falls back to heuristics when assets are absent.
models/**
!models/REGISTRY.md
!models/registry.json

# Public reference datasets pulled for model bootstrapping (FUNSD parquet, etc.) — local only.
data/reference/

# Phase 5: the cross-application graph is runtime state that accumulates across uploads.
# It is rebuilt deterministically from the packets (ApplicationGraph.build_from_packets),
# so the persisted pickle is not committed.
services/risk/graph_store/

# Web app (plan §A): SQLite user/case store + uploaded case files are runtime state with
# real user data — never commit them.
services/risk/app_data/
services/risk/case_store/

# NOTE: data/synthetic/packets/*.pdf ARE committed on purpose (tiny, synthetic, zero PII) so a
# fresh clone demos with no setup. The generator is deterministic, so they can also be regenerated.

# §10 Day 2: the rasterized clean/tampered IMAGE dataset (+ masks) for the image-forensics eval is
# regenerated on demand (python -m data.generator.build_image_dataset) — not committed. The committed
# eval RESULTS (results/image_forensics/) + a few curated demo examples are the durable artifacts.
data/synthetic/images/
# Throwaway generator-v2 QA previews (rendered by data/generator/_preview_*.py) — not committed.
data/synthetic/_preview/

# Synthetic loan packets + their ground-truth labels — DATASET, never committed.
# Regenerate locally:  python -m data.generator.generate   (writes packets/ + labels.json)
data/synthetic/packets/
data/synthetic/labels.json

# Browsable, cross-verified demo corpus — DATASET, never committed. Anchored to the repo root so it does
# NOT also ignore services/dashboard/public/demo/ (committed dashboard assets).
# Rebuild locally:  python scripts/build_demo_folder.py
/demo/

# data/real/ holds REAL, PII-bearing documents used ONLY for local validation of the real-document
# pipeline. NEVER commit them. data/real/.gitignore keeps just the folder structure + README.
# (Belt-and-suspenders: also ignored here at the repo root.)
data/real/**
!data/real/.gitignore
!data/real/README.md
!data/real/**/
!data/real/**/.gitkeep

# Local agent/editor/preview config (launch.json, settings.local.json) + planning notes.
# Kept out of the public repo; recreate locally as needed.
.claude/
**/CLAUDE.md
CLAUDE.md
plan.md
DASHBOARD_PLAN.md
